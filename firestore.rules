rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //
    // Collection: analyses
    // Document ID: analysisId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - status: string (required, enum)
    //   - progress: number (required)
    //   - fileName: string (required)
    //   - createdAt: timestamp (required)
    //   - results: map (optional)
    //   - reportUrl: string (optional)
    //
    // Collection: conversations
    // Document ID: analysisId
    // Fields:
    //   - analysisId: string (required)
    //   - messages: list (required)
    //
    // Collection: critic_evaluations
    // Document ID: auto-generated
    // Fields:
    //   - reportContext: string (required)
    //   - critique: string (required)
    //   - score: number (required)
    //   - embedding: list (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "blimacardoso@gmail.com" && request.auth.token.email_verified == true));
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (data.get('displayName', '') is string) &&
             (data.get('photoURL', '') is string);
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'status', 'progress', 'fileName', 'createdAt', 'currentStep']) &&
             data.userId is string &&
             data.status in ['pending', 'processing', 'waiting_user', 'completed', 'failed'] &&
             data.currentStep in ['analyst', 'engineer', 'reporter', 'reviewer', 'critic', 'done'] &&
             data.progress is number &&
             data.fileName is string &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (data.get('csvData', '') is string) &&
             (data.get('lastMessage', '') is string) &&
             (data.get('markdownReport', '') is string) &&
             (data.get('htmlReport', '') is string) &&
             (data.get('results', {}) is map) &&
             (data.get('userApproved', false) is bool) &&
             (data.get('userFeedback', '') is string);
    }

    function isValidUserPreference(data) {
      return data.keys().hasAll(['userId', 'content', 'embedding', 'createdAt']) &&
             data.userId is string &&
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 5000 &&
             data.embedding is list &&
             data.embedding.size() > 0 &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidCriticEvaluation(data) {
      return data.keys().hasAll(['reportContext', 'critique', 'score', 'embedding', 'createdAt']) &&
             data.reportContext is string &&
             data.critique is string &&
             data.score is number &&
             data.embedding is list &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidRegulation(data) {
      return data.keys().hasAll(['title', 'content', 'embedding', 'createdAt']) &&
             data.title is string &&
             data.content is string &&
             data.embedding is list &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidPendingRegulation(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt']) &&
             data.title is string &&
             data.content is string &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidAnalysisCache(data) {
      return data.keys().hasAll(['hash', 'results', 'createdAt']) &&
             data.hash is string &&
             data.results is map &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidAnalysis(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin()) && isValidAnalysis(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /conversations/{analysisId} {
      allow read: if isAuthenticated() && (exists(/databases/$(database)/documents/analyses/$(analysisId)) && (get(/databases/$(database)/documents/analyses/$(analysisId)).data.userId == request.auth.uid || isAdmin()));
      allow write: if isAuthenticated() && (exists(/databases/$(database)/documents/analyses/$(analysisId)) && (get(/databases/$(database)/documents/analyses/$(analysisId)).data.userId == request.auth.uid || isAdmin()));
    }

    match /user_preferences/{preferenceId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidUserPreference(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin()) && isValidUserPreference(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /regulations/{regulationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidRegulation(request.resource.data);
    }

    match /pending_regulations/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidPendingRegulation(request.resource.data);
    }

    match /critic_evaluations/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCriticEvaluation(request.resource.data);
      allow delete: if isAdmin();
    }

    match /system/status {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /analysis_cache/{id} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAnalysisCache(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
